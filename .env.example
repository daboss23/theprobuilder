# Summit Build Co — AI Creative System
# Copy this file to .env.local and fill in real values. Never commit .env.local.

# Anthropic Claude — primary copy generation (model: claude-sonnet-4-6)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# OpenAI — comparison copy (gpt-5.5) and image creatives (gpt-image-1, highest
# quality). Powers the Campaign Reactor "Generate creative" action.
OPENAI_API_KEY=your_openai_api_key_here

# Voyage AI — embeddings for the Reactor knowledge layer (voyage-3, 1024-dim).
# Without this, retrieval falls back to the curated demo intelligence.
VOYAGE_API_KEY=your_voyage_api_key_here

# Higgsfield — image + video creative via the official SDK (@higgsfield/client).
# Format: "KEY_ID:KEY_SECRET" from https://cloud.higgsfield.ai/api-keys
# Powers the Campaign Reactor generate_image / generate_video agent tools and the
# /api/generate-image and /api/generate-video routes. Without it, those degrade
# to demo mode (no creative is produced; copy still works).
HF_CREDENTIALS=your_key_id:your_key_secret
# Optional overrides for the Higgsfield endpoints/model:
# HIGGSFIELD_IMAGE_ENDPOINT=/v1/text2image/soul
# HIGGSFIELD_VIDEO_ENDPOINT=/v1/image2video/dop
# HIGGSFIELD_VIDEO_MODEL=dop-turbo

# Meta Ads MCP (Pipeboard) — live ad-performance tools for the Campaign Reactor
# agent via Anthropic's MCP connector. Get a token at https://pipeboard.co/api-tokens
# Without it, the agent simply runs without the Meta Ads tools.
PIPEBOARD_API_TOKEN=your_pipeboard_token_here
# Optional: point at a self-hosted Meta Ads MCP instead of Pipeboard's hosted one.
# META_ADS_MCP_URL=https://meta-ads.mcp.pipeboard.co/

# Supabase
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url_here
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here
