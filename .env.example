# Summit Build Co — AI Creative System
# Copy this file to .env.local and fill in real values. Never commit .env.local.

# Anthropic Claude — primary copy generation (model: claude-sonnet-4-6)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# OpenAI — comparison copy (gpt-5.5) and image creatives (gpt-image-1, highest
# quality). Powers the Campaign Reactor "Generate creative" action.
OPENAI_API_KEY=your_openai_api_key_here

# Voyage AI — embeddings for the Reactor knowledge layer (voyage-3, 1024-dim).
# Without this, retrieval falls back to the curated demo intelligence.
VOYAGE_API_KEY=your_voyage_api_key_here

# Higgsfield — image + video creative via the official SDK (@higgsfield/client).
# Format: "KEY_ID:KEY_SECRET" from https://cloud.higgsfield.ai/api-keys
# Powers the Campaign Reactor generate_image / generate_video agent tools and the
# /api/generate-image and /api/generate-video routes. Without it, those degrade
# to demo mode (no creative is produced; copy still works).
HF_CREDENTIALS=your_key_id:your_key_secret
# Optional overrides for the Higgsfield endpoints/model:
# HIGGSFIELD_IMAGE_ENDPOINT=/v1/text2image/soul
# HIGGSFIELD_VIDEO_ENDPOINT=/v1/image2video/dop
# HIGGSFIELD_VIDEO_MODEL=dop-turbo

# fal.ai — single gateway to the frontier image + video models (FLUX stills;
# Seedance / Kling / Veo / Wan video). One key unlocks all of them. Powers the
# Campaign Reactor generate_image / generate_video agent tools and the
# /api/generate-image and /api/generate-video routes. Get a key at
# https://fal.ai/dashboard/keys and add credits there. Without it (and no other
# image/video provider), creative generation degrades to demo mode.
FAL_KEY=your_fal_key_here
# Optional override for the fal still-image model (defaults to fal-ai/flux/dev):
# FAL_IMAGE_MODEL=fal-ai/flux/dev
# Optional overrides for fal video model endpoints (defaults track current gen):
# FAL_SEEDANCE_T2V=bytedance/seedance-2.0/text-to-video
# FAL_SEEDANCE_I2V=bytedance/seedance-2.0/image-to-video

# Google Gemini — Nano Banana 2 still-image model (fast creative variants).
# Powers the "nano-banana" image model. GOOGLE_API_KEY also accepted.
GEMINI_API_KEY=your_gemini_api_key_here

# Meta Ads MCP (Pipeboard) — live ad-performance tools for the Campaign Reactor
# agent via Anthropic's MCP connector. Get a token at https://pipeboard.co/api-tokens
# Without it, the agent simply runs without the Meta Ads tools.
PIPEBOARD_API_TOKEN=your_pipeboard_token_here
# Optional: point at a self-hosted Meta Ads MCP instead of Pipeboard's hosted one.
# META_ADS_MCP_URL=https://meta-ads.mcp.pipeboard.co/

# Meta's first-party Ads MCP (mcp.facebook.com/ads) — alternative to Pipeboard.
# Auth is an OAuth bearer access token (not a query param). Set this to test it.
# META_ADS_ACCESS_TOKEN=your_meta_oauth_access_token_here
# Optional override of the first-party endpoint URL.
# META_ADS_FIRSTPARTY_URL=https://mcp.facebook.com/ads
# Default provider when a run doesn't specify one: "pipeboard" (default) or "meta".
# A single run can override this by sending { "metaProvider": "meta" } in the POST body.
# META_ADS_PROVIDER=pipeboard

# Meta Marketing API (direct Graph API) — powers the /meta dashboard with live
# ad performance. Generate a System User token in Business Manager → Business
# Settings → System Users with ads_read, ads_management, business_management.
# The dashboard keeps showing curated demo data until aggregate spend clears
# META_LIVE_MIN_SPEND, then auto-switches to live numbers. Verify with GET /api/meta/status.
# META_ACCESS_TOKEN=your_long_lived_system_user_token_here
# META_APP_ID=your_app_id
# META_APP_SECRET=your_app_secret              # optional — enables appsecret_proof signing
# META_API_VERSION=v19.0                        # optional — Graph API version
# META_LIVE_MIN_SPEND=1000                      # optional — min total spend before live data shows

# Supabase
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url_here
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here
